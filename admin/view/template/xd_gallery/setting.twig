										<option value="21" {% if og_heading_title_size == 21 %} {{ ' selected="selected"' }} {% endif %}>21</option>
										<option value="22" {% if og_heading_title_size == 22 %} {{ ' selected="selected"' }} {% endif %}>22</option>
										<option value="23" {% if og_heading_title_size == 23 %} {{ ' selected="selected"' }} {% endif %}>23</option>
										<option value="24" {% if og_heading_title_size == 24 %} {{ ' selected="selected"' }} {% endif %}>24</option>
										<option value="26" {% if og_heading_title_size == 26 %} {{ ' selected="selected"' }} {% endif %}>26</option>
