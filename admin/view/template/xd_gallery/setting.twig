{{ header }}{{ column_left }}
<div id="content">
	<div class="page-header">
		<div class="container-fluid">
			<div class="pull-right">
				<button type="submit" form="form-gallery" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary">
					<i class="fa fa-save"></i>
				</button>
				<a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default">
					<i class="fa fa-reply"></i>
				</a>
			</div>

			<h1>{{ heading_title }}</h1>
			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
					<li>
						<a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a>
					</li>
				{% endfor %}
			</ul>
		</div>
	</div>
	<div class="container-fluid">
		{% if error_warning %}
			<div class="alert alert-danger">
				<i class="fa fa-exclamation-circle"></i>
				{{ error_warning }}
				<button type="button" class="close" data-dismiss="alert">&times;</button>
			</div>
		{% endif %}
		{% if success %}
			<div class="alert alert-success">
				<i class="fa fa-check-circle"></i>
				{{ success }}
				<button type="button" class="close" data-dismiss="alert">&times;</button>
			</div>
		{% endif %}
		<div class="panel panel-default">
			<div class="panel-heading">
				<h3 class="panel-title">
					<i class="fa fa-cogs"></i>
					{{ text_form }}</h3>
			</div>
			<div class="panel-body">
				<form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-gallery" class="form-horizontal">
					<ul class="nav nav-tabs">
						<li class="active">
							<a href="#tab-general" data-toggle="tab">{{ tab_setting }}</a>
						</li>
						<li>
							<a href="#tab-album" data-toggle="tab">Фотогалерея</a>
						</li>
						<li>
							<a href="#tab-video" data-toggle="tab">Видеогалерея</a>
						</li>
					</ul>
					<div class="tab-content">

						<div class="tab-pane active" id="tab-general">
							<div class="form-group">
								<label class="col-sm-2 control-label" for="input-sitemap">Добавить в карту сайта:</label>
								<div class="col-sm-10">
									<select name="og_sitemap" id="input-sitemap" class="form-control">
										<option value="0" {% if og_sitemap == 0 %} {{ ' selected="selected"' }} {% endif %}>Нет</option>
										<option value="1" {% if og_sitemap == 1 %} {{ ' selected="selected"' }} {% endif %}>Да</option>
									</select>
								</div>
							</div>
                            <hr />
							<div class="form-group">
								<label class="col-sm-2 control-label" for="input-show-title">Показывать заголовок:</label>
								<div class="col-sm-10">
									<select name="og_show_title" id="input-show-title" class="form-control">
										<option value="0" {% if og_show_title == 0 %} {{ ' selected="selected"' }} {% endif %}>Нет</option>
										<option value="1" {% if og_show_title == 1 %} {{ ' selected="selected"' }} {% endif %}>Да</option>
									</select>
								</div>
							</div>
							<div class="form-group">
								<label class="col-sm-2 control-label" for="input-title-position">Положение заголовка:</label>
								<div class="col-sm-10">
									<select name="og_title_position" id="input-title-position" class="form-control">
										<option value="left" {% if og_title_position == 'left' %} {{ ' selected="selected"' }} {% endif %}>Слева</option>
										<option value="center" {% if og_title_position == 'center' %} {{ ' selected="selected"' }} {% endif %}>По центру</option>
										<option value="right" {% if og_title_position == 'right' %} {{ ' selected="selected"' }} {% endif %}>Справа</option>
									</select>
								</div>
							</div>                              
							<div class="form-group">
